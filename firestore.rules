rules_version = '2';

// GateMate Firestore security rules.
//
// Trust model: Firebase Auth's email-link sign-in confirms email ownership.
// We require `request.auth.token.email_verified == true` on every create, and
// pin `email` and `userId` to the auth claims so the client can't impersonate
// anyone else. Reads are restricted to active, verified, non-expired profiles.
service cloud.firestore {
  match /databases/{database}/documents {

    match /layover_profiles/{profileId} {

      // Read: only active, email-verified profiles whose layover hasn't ended.
      allow read: if resource.data.status == 'active'
                  && resource.data.emailVerified == true
                  && resource.data.expiresAt > request.time;

      // Create: must be signed in via Firebase Auth, email must be verified,
      // and the doc's userId/email must match the auth claims.
      allow create: if request.auth != null
                    && request.auth.token.email_verified == true
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.emailVerified == true
                    && request.resource.data.consent == true
                    && request.resource.data.status == 'active'
                    && request.resource.data.revealCount == 0
                    && request.resource.data.keys().hasAll([
                         'userId', 'nickname', 'age', 'gender', 'interestedIn',
                         'airportCode', 'layoverStart', 'layoverEnd',
                         'instagram', 'email', 'emailVerified', 'vibe', 'consent',
                         'createdAt', 'expiresAt', 'status', 'revealCount'
                       ])
                    && request.resource.data.age is int
                    && request.resource.data.age >= 18 && request.resource.data.age <= 99
                    && request.resource.data.nickname is string
                    && request.resource.data.nickname.size() > 0
                    && request.resource.data.nickname.size() <= 40
                    && request.resource.data.instagram is string
                    && request.resource.data.instagram.size() > 0
                    && request.resource.data.instagram.size() <= 32
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 254
                    && request.resource.data.airportCode is string
                    && request.resource.data.airportCode.size() == 3
                    && request.resource.data.gender in ['woman', 'man', 'nonbinary', 'other']
                    && request.resource.data.interestedIn in ['women', 'men', 'everyone', 'friends']
                    && request.resource.data.vibe is list
                    && request.resource.data.vibe.size() <= 6
                    && request.resource.data.layoverStart is timestamp
                    && request.resource.data.layoverEnd is timestamp
                    && request.resource.data.layoverEnd > request.resource.data.layoverStart
                    && request.resource.data.expiresAt == request.resource.data.layoverEnd;

      // Update: only the revealCount field, and only by exactly +1.
      // Anyone (signed in or not) can tap "Reveal Instagram" to bump the counter.
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['revealCount'])
                    && request.resource.data.revealCount == resource.data.revealCount + 1;

      // No client deletes. Cleanup runs server-side (scheduled function or admin).
      allow delete: if false;
    }
  }
}
